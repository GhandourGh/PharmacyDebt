# Copy to `.env` (optional). Vars already in the environment are not overwritten.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TIMEOUT=25
OLLAMA_CHAT_TIMEOUT=180
# false = no chain-of-thought (faster, cleaner chat). true only if you use a thinking model on purpose.
OLLAMA_THINK=false
OLLAMA_CONV_NUM_PREDICT=160
OLLAMA_INTENT_NUM_PREDICT=120
# Skip Ollama JSON intent when keyword rules are confident (big speedup for hi/help/undo).
OLLAMA_RULES_FIRST=true
# Cap for “top N debtors” and default list size (1–2000).
CHAT_TOP_DEBTORS_MAX=500
# false = fast template text after payments/balance; true = extra LLM pass for wording.
OLLAMA_REPHRASE=false
